@article {Bzdok327437,
	author = {Bzdok, Danilo and Engemann, Denis and Grisel, Olivier and Varoquaux, Ga{\"e}l and Thirion, Bertrand},
	title = {Prediction and inference diverge in biomedicine: Simulations and real-world data},
	elocation-id = {327437},
	year = {2018},
	doi = {10.1101/327437},
	publisher = {Cold Spring Harbor Laboratory},
	abstract = {In the 20th century many advances in biological knowledge and evidence-based medicine were supported by p-values and accompanying methods. In the beginning 21st century, ambitions towards precision medicine put a premium on detailed predictions for single individuals. The shift causes tension between traditional methods used to infer statistically significant group differences and burgeoning machine-learning tools suited to forecast an individual{\textquoteright}s future. This comparison applies the linear model for identifying significant contributing variables and for finding the most predictive variable sets. In systematic data simulations and common medical datasets, we explored how statistical inference and pattern recognition can agree and diverge. Across analysis scenarios, even small predictive performances typically coincided with finding underlying significant statistical relationships. However, even statistically strong findings with very low p-values shed little light on their value for achieving accurate prediction in the same dataset. More complete understanding of different ways to define {\textquoteleft}important{\textquoteright} associations is a prerequisite for reproducible research findings that can serve to personalize clinical care.},
	URL = {https://www.biorxiv.org/content/early/2018/05/21/327437},
	eprint = {https://www.biorxiv.org/content/early/2018/05/21/327437.full.pdf},
	journal = {bioRxiv}
}
